{
  "name": "cross-border-ecommerce-ai",
  "version": "1.0.0",
  "description": "跨境电商AI服务平台",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend-py\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:backend-py": "cd backend-py && python -m uvicorn main:app --reload --port 8000",
    "build": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "install:py": "cd backend-py && pip install -r requirements.txt"
  },
  "keywords": ["ecommerce", "ai", "amazon", "cross-border"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
